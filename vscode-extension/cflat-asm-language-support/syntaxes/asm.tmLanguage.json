{
  "$schema": "https://raw.githubusercontent.com/martinring/tmlanguage/master/tmlanguage.json",
  "name": "CustomAssembly",
  "scopeName": "source.asm",
  "patterns": [
    { "include": "#comments" },
    { "include": "#labels" },
    { "include": "#opcodes" },
    { "include": "#registers" },
    { "include": "#directives" },
    { "include": "#constants" }
  ],
  "repository": {
    "comments": {
      "patterns": [
        {
          "name": "comment.line.semicolon.asm",
          "match": ";.*$"
        }
      ]
    },
    "labels": {
      "patterns": [
        {
          "name": "entity.name.function.label.asm",
          "match": "^[a-zA-Z_][a-zA-Z0-9_]*:"
        }
      ]
    },
    "opcodes": {
      "patterns": [
        {
          "name": "keyword.control.assembly.asm",
          "match": "\\b(LDA|STA|ADD|SUB|MUL|DIV|PUSH|POP|CALL|RET|JMP|JZ|JNZ|TAB|DECA|HLT)\\b"
        }
      ]
    },
    "registers": {
      "patterns": [
        {
          "name": "variable.parameter.register.asm",
          "match": "\\b(B)\\b"
        }
      ]
    },
    "directives": {
      "patterns": [
        {
          "name": "keyword.other.directive.asm",
          "match": "\\b(ORG|EQU|DB|DW)\\b"
        }
      ]
    },
    "constants": {
      "patterns": [
        {
          "name": "constant.numeric.hex.asm",
          "match": "#?0x[0-9a-fA-F]+\\b"
        }
      ]
    }
  }
}
