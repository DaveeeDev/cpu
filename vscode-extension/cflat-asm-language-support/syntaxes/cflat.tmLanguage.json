{
	"$schema": "https://raw.githubusercontent.com/martinring/tmlanguage/master/tmlanguage.json",
	"name": "CFlat",
	"scopeName": "source.cflat",
	"patterns": [
    	{ "include": "#comments" },
		{ "include": "#keywords" },
		{ "include": "#storage-types" },
		{ "include": "#constants" },
		{ "include": "#operators" }
    ],
    "repository": {
		"comments": {
			"patterns": [
				{
				"name": "comment.line.double-slash.meinesprache",
				"match": "//.*$"
				}
			]
		},
		"keywords": {
			"patterns": [
				{
				"name": "keyword.control.meinesprache",
				"match": "\\b(if|else|for|while|break|return)\\b"
				}
			]
		},
		"storage-types": {
			"patterns": [
				{
				"name": "storage.type.meinesprache",
				"match": "\\b(uint8|bool)\\b"
				},
				{
				"name": "storage.modifier.meinesprache",
				"match": "\\bconst\\b"
				}
			]
		},
		"constants": {
			"patterns": [
				{
				"name": "constant.language.boolean.meinesprache",
				"match": "\\b(true|false)\\b"
				},
				{
				"name": "constant.numeric.meinesprache",
				"match": "\\b\\d+\\b"
				}
			]
		},
		"operators": {
			"patterns": [
				{
				"name": "keyword.operator.comparison.meinesprache",
				"match": "==|!="
				},
				{
				"name": "keyword.operator.assignment.meinesprache",
				"match": "="
				},
				{
				"name": "keyword.operator.arithmetic.meinesprache",
				"match": "\\+|\\-|\\*"
				}
			]
		}
    }
}